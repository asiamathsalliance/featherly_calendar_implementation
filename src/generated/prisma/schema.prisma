// Featherly MVP — Auth.js + domain models

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPPORT_WORKER
  PROVIDER
  CLIENT
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  PENDING
  ACCEPTED
  REJECTED
  INTERVIEW
}

enum InterviewProposalStatus {
  NONE
  AWAITING_WORKER
  WORKER_ACCEPTED
  WORKER_REQUESTED_CHANGE
}

// Auth.js models (https://authjs.dev/reference/adapter/prisma)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                          String    @id @default(cuid())
  name                        String?
  email                       String?   @unique
  emailVerified               DateTime?
  image                       String?
  role                        UserRole  @default(SUPPORT_WORKER)
  onboardingCompleted         Boolean   @default(false)
  bio                         String?   @db.Text
  funFact                     String?   @db.Text
  /// Slider quiz (1–10); null until completed
  preferenceQuizAnswers       Json?
  preferenceQuizCompletedAt   DateTime?
  /// Top 3 category labels stored as JSON string[] (avoids adapter issues with PG text[])
  preferenceQuizTopCategories Json?

  accounts       Account[]
  sessions       Session[]
  jobsAsProvider Job[]         @relation("ProviderJobs")
  applications   Application[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id                 String           @id @default(cuid())
  title              String
  summary            String           @db.Text
  startAt            DateTime
  endAt              DateTime
  tags               String[]
  clientName         String
  /// Australian location line from autocomplete (suburb, city, state)
  region             String?
  clientPhotoUrl     String?
  personality        String?          @db.Text
  preferences        String?          @db.Text
  reqAgeMin          Int?
  reqAgeMax          Int?
  reqGender          String?
  reqPhysicalAbility String?          @db.Text
  description        String           @db.Text
  /// Gross pay rate in whole Australian dollars per hour
  pricePerHourAud    Int              @default(45)
  providerId         String
  provider           User             @relation("ProviderJobs", fields: [providerId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  applications       Application[]
  quizTemplate       JobQuizTemplate?
}

model Application {
  id                      String                  @id @default(cuid())
  jobId                   String
  job                     Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId                String
  worker                  User                    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  applicantName           String?
  applicantGender         String?
  applicantAge            Int?
  applicantRegion         String?
  rejectionReason         String?                 @db.Text
  status                  ApplicationStatus       @default(DRAFT)
  interviewAt             DateTime?
  interviewProposalStatus InterviewProposalStatus @default(NONE)
  matchScore              Float?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  quiz                    QuizAttempt?

  @@unique([jobId, workerId])
  @@index([jobId])
  @@index([workerId])
}

model JobQuizTemplate {
  id        String   @id @default(cuid())
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  questions Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizAttempt {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questions     Json
  answers       Json?
  elaborations  Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
